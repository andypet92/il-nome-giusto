# Copia questo file in .env.local e inserisci i tuoi valori reali

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=inserisci-qui-la-tua-chiave-anthropic

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=inserisci-qui-la-chiave-segreta-stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=inserisci-qui-la-chiave-pubblica-stripe
STRIPE_WEBHOOK_SECRET=inserisci-qui-il-webhook-secret-stripe

# URL del sito
NEXT_PUBLIC_SITE_URL=http://localhost:3000
